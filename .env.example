# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=xxx
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=xxx.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=xxx
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=xxx.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=xxx
NEXT_PUBLIC_FIREBASE_APP_ID=xxx

# Database (Firestore)
# Add your Firebase service account credentials in FIREBASE_ADMIN_SDK
# Or use Firebase Admin SDK JSON directly

# OpenAI (for AI features)
OPENAI_API_KEY=sk-xxx

# GitHub OAuth (optional - for social connections)
GITHUB_CLIENT_ID=xxx
GITHUB_CLIENT_SECRET=xxx

# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID=xxx
LINKEDIN_CLIENT_SECRET=xxx

# Careerjet Publisher API
# Use your publisher API key (not the partner portal URL)
CAREERJET_API_KEY=your_careerjet_api_key_here

# Jooble Jobs API
JOOBLE_API_KEY=your_jooble_api_key_here
